# ============================================================================
# Xuanwu Auth — environment template.  Copy to `.env` and adjust for local dev.
# Real secrets NEVER go in git. Every value is consumed via pydantic-settings
# (app/core/config.py, Phase 1) — never read os.environ directly.
# ============================================================================

# --- Docker host ports (left side only; change if they clash with other stacks) ---
API_HOST_PORT=8000
DB_HOST_PORT=3307
REDIS_HOST_PORT=6380

# --- App ---
APP_ENV=development                 # development | staging | production
APP_NAME=xuanwu
LOG_LEVEL=info
# Comma-separated list of allowed CORS origins (the frontend)
CORS_ORIGINS=http://localhost:3000

# --- Database (MySQL 8 only) ---
# async driver for the app, sync driver (pymysql) is used by Alembic
DATABASE_URL=mysql+asyncmy://rv:rv@db:3306/xuanwu
DATABASE_URL_SYNC=mysql+pymysql://rv:rv@db:3306/xuanwu

# --- Redis (sessions / token jti state / cache / Celery broker) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false      # true runs tasks inline (no worker needed)

# --- GeoIP (audit-trail country resolution) ---
GEOIP_PROVIDER=none                 # none | maxmind
GEOIP_DB_PATH=config/geoip/GeoLite2-Country.mmdb

# --- Crypto / secrets (generate strong random values for real envs) ---
SECRET_KEY=dev-only-change-me
BLIND_INDEX_KEY=dev-only-change-me-too
# RS256 JWT keypair (auto-generated for dev in Phase 3 if missing)
JWT_PRIVATE_KEY_PATH=config/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=config/keys/jwt_public.pem

# --- JWT ---
JWT_ISSUER=xuanwu
JWT_AUDIENCE=xuanwu

# --- Token / session policy (spec §5.2) ---
ACCESS_TOKEN_TTL=900                # 15 minutes (seconds)
REFRESH_TOKEN_TTL=604800            # 7 days (seconds)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_TTL=900               # 15 minutes (seconds)

# --- Auth cookies ---
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token
COOKIE_SECURE=false                 # true in production (HTTPS only)
COOKIE_SAMESITE=lax                 # lax | strict | none
# COOKIE_DOMAIN=.rarevintage.com.au

# --- Password policy ---
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=80
PASSWORD_MIN_SCORE=2                # zxcvbn score floor (0..4)

# --- TOTP / API keys ---
TOTP_ISSUER=Xuanwu
API_KEY_NONCE_WINDOW_MS=5000

# --- Email (dev: MailHog) ---
EMAIL_PROVIDER=smtp                 # mock | smtp | sendgrid
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM=no-reply@rarevintage.com.au
EMAIL_FROM_NAME=Rare Vintage
EMAIL_DEFAULT_LANGUAGE=en
SENDGRID_API_KEY=
FRONTEND_URL=http://localhost:3000  # base URL for links in emails

# --- SMS (dev: mock) ---
SMS_PROVIDER=mock                   # mock | twilio_sms | twilio_verify | aws_sns
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=                 # E.164 sender for twilio_sms, e.g. +61400000000
TWILIO_SERVICE_SID=                 # Twilio Verify service SID (twilio_verify only)
AWS_REGION=ap-southeast-2           # used by the aws_sns provider
SMS_CONTENT_TEMPLATE=Your Rare Vintage verification code is {code}.
SMS_CODE_TTL=600

# --- Object storage (dev: MinIO) ---
STORAGE_PROVIDER=local              # local | s3
UPLOAD_DIR=uploads                  # local provider base directory
UPLOAD_MAX_SIZE=10485760            # 10 MB
UPLOAD_EXTENSIONS=pdf,jpg,jpeg,png
S3_ENDPOINT_URL=http://minio:9000   # blank for real AWS S3
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=xuanwu-dev
S3_REGION=us-east-1
S3_URL_EXPIRATION=3600              # presigned URL lifetime (seconds)
S3_SSE=                             # AES256 for AWS S3; blank for MinIO

# --- Captcha (Phase 13) ---
CAPTCHA_PROVIDER=none               # none | recaptcha
RECAPTCHA_SECRET=
RECAPTCHA_SITE_KEY=
